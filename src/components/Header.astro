---
const base = import.meta.env.BASE_URL.replace(/\/+$/, ''); // "/beta"
const nav = [
  { label: 'Home', href: base + '/' },
  { label: 'Dispatches', href: base + '/dispatches' },
  { label: 'Field Notes', href: base + '/field-notes' },
  { label: 'Lectures', href: base + '/lectures' },
  { label: 'Curiously Polar', href: base + '/curiously-polar' },
  { label: 'Books', href: base + '/books' },
];
const current = Astro.url.pathname.replace(/\/$/, '');
---

<header class="site-header">
  <div class="container header-inner">
    <a class="logo" href={base + '/'} aria-label="Henry Páll Wulff — home">
      <span class="logo__box">
        <img class="logo__mark" src={base + '/logo-mark.png'} alt="Henry Páll Wulff" width="400" height="400" />
      </span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" />
    <label for="nav-toggle" class="nav-burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => {
        const path = item.href.replace(/\/$/, '');
        const active = current === path;
        return (
          <a href={item.href} class:list={['nav__link', { 'is-active': active }]}>
            <span class="nav__label">{item.label}</span>
            {active && (
              <svg class="nav__caret" width="11" height="7" viewBox="0 0 11 7" fill="none" aria-hidden="true">
                <path d="M1 1.5L5.5 6L10 1.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
          </a>
        );
      })}
    </nav>

    <div class="header-actions">
      <div class="socials">
        <a href="https://facebook.com" class="icon" aria-label="Facebook" rel="me">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.5-1.5h1.6V3.6c-.28-.04-1.24-.12-2.36-.12-2.33 0-3.94 1.42-3.94 4.04V9.9H7.9V13h2.4v8h3.2z"/></svg>
        </a>
        <a href="https://instagram.com" class="icon" aria-label="Instagram" rel="me">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3.5" y="3.5" width="17" height="17" rx="4.5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://linkedin.com" class="icon" aria-label="LinkedIn" rel="me">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M6.94 8.5V19H3.9V8.5h3.04zM5.42 3.9a1.76 1.76 0 110 3.52 1.76 1.76 0 010-3.52zM20.1 19h-3.03v-5.6c0-1.34-.03-3.06-1.87-3.06-1.87 0-2.16 1.46-2.16 2.96V19H9.98V8.5h2.92v1.43h.04c.4-.77 1.4-1.58 2.88-1.58 3.08 0 3.65 2.03 3.65 4.66V19z"/></svg>
        </a>
      </div>
      <button class="icon icon--search" aria-label="Search" type="button">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="6.5"/><line x1="20" y1="20" x2="16" y2="16"/></svg>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header { background: var(--paper); }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    /* logo defines the height; nav + icons centre against it */
  }

  /* Logo — 165×165 navy square, flush to the top edge, thin inset frame */
  .logo { display: inline-flex; flex: 0 0 auto; }
  .logo__box {
    position: relative;
    width: 165px;
    height: 165px;
    background: var(--navy);
    display: grid;
    place-items: center;
  }
  .logo__mark { position: relative; width: 128px; height: 128px; object-fit: contain; }

  /* Navigation */
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.2vw, 2rem);
    margin-left: auto;
  }
  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 300;            /* Poppins Light */
    letter-spacing: 0.06em;
    color: var(--navy);
    padding-bottom: 9px;
    white-space: nowrap;
  }
  .nav__link:hover { opacity: 0.7; }
  .nav__link.is-active { font-weight: 600; }   /* Poppins SemiBold */
  .nav__caret { display: inline-block; margin-bottom: 1px; }
  .nav__link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 20px;
    height: 3px;
    background: var(--navy);
  }

  /* Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--navy);
  }
  .socials { display: flex; align-items: center; gap: 7px; }  /* tight, per Figma */
  .icon {
    display: inline-grid; place-items: center;
    width: 22px; height: 22px;
    color: var(--navy);
    background: none; border: 0; padding: 0; cursor: pointer;
  }
  .icon:hover { opacity: 0.6; }
  .icon--search { margin-left: 4px; }

  /* Mobile menu (CSS only) */
  .nav-toggle, .nav-burger { display: none; }
  .nav-burger {
    width: 30px; height: 22px; margin-left: auto;
    flex-direction: column; justify-content: space-between; cursor: pointer;
  }
  .nav-burger span { display: block; height: 2px; background: var(--navy); }

  @media (max-width: 980px) {
    .logo__box { width: 104px; height: 104px; }
    .logo__mark { width: 82px; height: 82px; }
    .nav-burger { display: flex; }
    .header-actions { order: 3; }
    .nav {
      order: 4;
      flex-basis: 100%;
      display: none;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.85rem;
      padding-bottom: 1.25rem;
    }
    .nav-toggle:checked ~ .nav { display: flex; }
    .nav__link { padding-bottom: 0; }
    .nav__link.is-active::after { display: none; }
  }
</style>
