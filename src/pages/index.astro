---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="intro container">
    <p class="eyebrow">Narrating the Poles</p>
    <h1>The foundation is in place.</h1>
    <div class="rule"></div>
    <p class="lede">
      Typography, colours, the header, and the footer now match the design. The
      nine pages — Home, Dispatches, Field Notes, Lectures, Curiously Polar, the
      Podcast, and Books — come next, and each will appear here as it is built.
    </p>

    <div class="swatches" aria-hidden="true">
      <span class="tag">Cryosphere</span>
      <a class="btn"><b>Read</b> Sample</a>
      <a class="btn btn--solid"><b>Pre</b> Order</a>
    </div>
  </section>

  <section class="watermark-demo container">
    <p class="watermark">Field Notes</p>
  </section>
</BaseLayout>

<style>
  .intro { padding: clamp(3rem, 8vw, 6rem) var(--gutter); max-width: 820px; }
  .lede { font-size: 1.15rem; color: var(--ink); }
  .swatches { display: flex; align-items: center; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }
  .watermark-demo { padding-bottom: 2rem; overflow: hidden; }
</style>
