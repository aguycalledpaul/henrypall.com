---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = ['Cryosphere', 'Leadership', 'Changing Poles'];
const notes = [
  { title: 'The greatest thing in the world is to know how to belong to oneself', date: 'December 12, 2025' },
  { title: 'The greatest thing in the world is to know how to belong to oneself', date: 'November 30, 2025' },
  { title: 'The greatest thing in the world is to know how to belong to oneself', date: 'November 17, 2025' },
];
---

<BaseLayout>
  <!-- ============ HERO ============ -->
  <section class="hero container">
    <span class="hero__date">April 8, 2026</span>
    <div class="hero__media placeholder"></div>
    <article class="hero__card">
      <span class="tag hero__tag">Cryosphere</span>
      <h2 class="hero__title">Thin Ice: The Arctic Sea Ice Maximum of 2026 and the World That Depends On It</h2>
      <p class="hero__excerpt">On March 15, the Arctic sea ice reached its 2026 maximum: 14.29 million km², the lowest in the 48-year satellite record. An area twice the size of Texas that never froze. The ice is telling its story.</p>
      <a class="readmore readmore--light" href="#"><b>Read</b> More</a>
    </article>
    <div class="hero__nav">
      <button class="arrow" aria-label="Previous">&larr;</button>
      <button class="arrow" aria-label="Next">&rarr;</button>
    </div>
  </section>

  <!-- ============ SUBSCRIBE ============ -->
  <section class="subscribe">
    <div class="container subscribe__inner">
      <h2 class="subscribe__title">Subscribe to my journal</h2>
      <span class="dash"></span>
      <p class="subscribe__sub">Get more content from the polar regions, inspiration, tips and exclusive offers sent straight to your inbox.</p>
      <form class="subscribe__form" onsubmit="return false">
        <input type="email" placeholder="Your email address" aria-label="Your email address" />
      </form>
      <button class="subscribe__btn" type="submit">Subscribe</button>
    </div>
  </section>

  <!-- ============ CATEGORY TILES ============ -->
  <section class="tiles container">
    {categories.map((c) => (
      <a class="tile" href="#">
        <span class="placeholder tile__img"></span>
        <span class="tag tile__tag">{c}</span>
      </a>
    ))}
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="about container">
    <span class="watermark about__wm">About</span>
    <div class="about__media">
      <span class="about__square"></span>
      <span class="placeholder about__img"></span>
    </div>
    <div class="about__body">
      <h2 class="about__title">Love has no age no limit and no death.</h2>
      <span class="rule"></span>
      <p class="about__text">Consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
      <a class="readmore" href="#"><b>Read</b> More</a>
    </div>
  </section>

  <!-- ============ FIELD NOTES ============ -->
  <section class="fieldnotes container">
    <span class="watermark fieldnotes__wm">Field Notes</span>
    <div class="fieldnotes__grid">
      <div class="fieldnotes__intro">
        <blockquote class="fieldnotes__quote">Do not mind anything that anyone tells you about anyone else. Judge everyone and everything for yourself.</blockquote>
        <div class="nav-arrows">
          <button class="arrow" aria-label="Previous">&larr;</button>
          <button class="arrow" aria-label="Next">&rarr;</button>
        </div>
      </div>
      {notes.map((n) => (
        <article class="note">
          <span class="placeholder note__img"></span>
          <h3 class="note__title">{n.title}</h3>
          <span class="note__date">{n.date}</span>
        </article>
      ))}
    </div>
  </section>

  <!-- ============ LECTURES ============ -->
  <section class="lectures container">
    <div class="lectures__media placeholder"></div>
    <article class="lectures__card">
      <span class="lectures__tag">Lectures</span>
      <h3 class="lectures__title">The greatest thing in the world is to know to belong to oneself</h3>
      <a class="readmore" href="#"><b>Read</b> More</a>
    </article>
    <span class="lectures__label">Lectures</span>
    <div class="nav-arrows lectures__nav">
      <button class="arrow" aria-label="Previous">&larr;</button>
      <button class="arrow" aria-label="Next">&rarr;</button>
    </div>
  </section>
</BaseLayout>

<style>
  /* shared read-more */
  .readmore { font-size: 0.85rem; color: var(--navy); border-left: 2px solid currentColor; padding-left: 8px; }
  .readmore b { font-weight: 600; }
  .readmore--light { color: #fff; }

  .arrow {
    width: 38px; height: 38px;
    background: var(--navy); color: #fff;
    border: 0; cursor: pointer;
    display: grid; place-items: center;
    font-size: 1rem;
  }
  .arrow:hover { background: var(--navy-800); }
  .nav-arrows { display: flex; gap: 8px; }

  /* ---------- HERO ---------- */
  .hero { position: relative; padding-top: 3rem; padding-bottom: 5rem; }
  .hero__media {
    width: 66%;
    aspect-ratio: 16 / 11;
    margin-left: 56px;
  }
  .hero__date {
    position: absolute;
    left: 8px; top: 210px;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    letter-spacing: 0.14em;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .hero__card {
    position: absolute;
    top: 130px; right: 0;
    width: 51%;
    background: var(--navy);
    color: #fff;
    padding: 2.6rem 2.6rem 1.6rem;
  }
  .hero__tag { position: absolute; top: -14px; left: 2.6rem; }
  .hero__title {
    color: #fff;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    text-transform: uppercase;
    line-height: 1.15;
    margin-bottom: 0.9rem;
  }
  .hero__excerpt { font-size: 0.9rem; line-height: 1.6; color: #c3ccd1; margin-bottom: 1.4rem; }
  .hero__card .readmore { display: inline-block; float: right; }
  .hero__nav {
    position: absolute;
    left: 20px; bottom: 3.2rem;
    display: flex; flex-direction: column; gap: 8px;
  }

  /* ---------- SUBSCRIBE ---------- */
  .subscribe { background: var(--navy); color: #fff; padding: 3.6rem 0; margin-top: 1rem; }
  .subscribe__inner { text-align: center; max-width: 780px; }
  .subscribe__title { color: #fff; text-transform: uppercase; letter-spacing: 0.22em; font-size: 1.25rem; margin-bottom: 0.6rem; }
  .dash { display: block; width: 26px; height: 2px; background: rgba(255,255,255,0.7); margin: 0.6rem auto 1.1rem; }
  .subscribe__sub { font-size: 0.85rem; color: #b9c4c9; margin-bottom: 1.6rem; }
  .subscribe__form input {
    width: 100%; max-width: 470px;
    padding: 0.85rem 1.2rem;
    border: 0; border-radius: 2px;
    font-family: inherit; font-size: 0.9rem;
    text-align: center;
  }
  .subscribe__btn {
    margin-top: 1.3rem;
    background: none; border: 0; color: #fff;
    font-family: inherit; font-size: 0.9rem; letter-spacing: 0.04em;
    cursor: pointer;
  }
  .subscribe__btn:hover { opacity: 0.75; }

  /* ---------- TILES ---------- */
  .tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.6rem; padding-top: 4rem; padding-bottom: 4rem; }
  .tile { position: relative; display: block; }
  .tile__img { display: block; aspect-ratio: 3 / 2; }
  .tile__tag { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); }

  /* ---------- ABOUT ---------- */
  .about { position: relative; padding-top: 5rem; padding-bottom: 5rem; }
  .about__wm { position: absolute; top: 1rem; right: 0; z-index: 0; }
  .about__media, .about__body { position: relative; z-index: 1; }
  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }
  .about__media { position: relative; }
  .about__square { position: absolute; left: -22px; bottom: -22px; width: 78%; height: 82%; background: var(--navy); }
  .about__img { position: relative; display: block; aspect-ratio: 1 / 1; }
  .about__title { font-size: clamp(1.5rem, 2.4vw, 2rem); text-transform: uppercase; }
  .about__text { color: var(--muted); max-width: 340px; margin: 1.4rem 0 1.4rem auto; font-size: 0.9rem; }
  .about__body .readmore { margin-left: auto; display: inline-block; }
  .about__body { text-align: left; }

  /* ---------- FIELD NOTES ---------- */
  .fieldnotes { position: relative; padding-top: 4rem; padding-bottom: 4rem; }
  .fieldnotes__wm { position: absolute; top: 0; left: 0; z-index: 0; }
  .fieldnotes__grid {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 190px repeat(3, 1fr);
    gap: 1.75rem;
    align-items: start;
    padding-top: 5rem;
  }
  .fieldnotes__quote { font-size: 0.85rem; color: var(--muted); border-left: 2px solid var(--navy); padding-left: 1rem; margin: 0 0 1.5rem; line-height: 1.6; }
  .note__img { display: block; aspect-ratio: 1 / 1; margin-bottom: 1rem; }
  .note__title { font-size: 0.92rem; text-transform: uppercase; line-height: 1.35; margin-bottom: 0.6rem; }
  .note__date { font-size: 0.78rem; color: var(--muted); }

  /* ---------- LECTURES ---------- */
  .lectures { position: relative; padding-top: 3rem; padding-bottom: 6rem; }
  .lectures__media { width: 63%; aspect-ratio: 16 / 10; }
  .lectures__card {
    position: absolute;
    right: 40px; top: 110px;
    width: 46%;
    background: #fff;
    box-shadow: 0 18px 50px rgba(17, 41, 46, 0.12);
    padding: 3rem 2.6rem;
    text-align: center;
  }
  .lectures__tag { display: block; text-transform: uppercase; letter-spacing: 0.22em; font-size: 0.7rem; color: var(--muted); margin-bottom: 1.4rem; }
  .lectures__title { font-size: clamp(1.2rem, 1.9vw, 1.6rem); text-transform: uppercase; line-height: 1.3; margin-bottom: 1.6rem; }
  .lectures__card .readmore { display: inline-block; }
  .lectures__label {
    position: absolute; right: 6px; bottom: 150px;
    writing-mode: vertical-rl;
    text-transform: uppercase; letter-spacing: 0.2em;
    font-size: 0.72rem; color: var(--muted);
  }
  .lectures__nav { position: absolute; right: 40px; bottom: 2.5rem; }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .hero { padding-bottom: 2rem; }
    .hero__media { width: 100%; margin-left: 0; }
    .hero__card { position: static; width: 100%; margin-top: -3rem; margin-left: auto; margin-right: 0; }
    .hero__card { width: 88%; }
    .hero__date, .hero__nav { display: none; }
    .about { grid-template-columns: 1fr; }
    .about__text, .about__body .readmore { margin-left: 0; }
    .fieldnotes__grid { grid-template-columns: 1fr 1fr; }
    .lectures__media { width: 100%; }
    .lectures__card { position: static; width: 100%; margin-top: -2rem; }
    .lectures__label, .lectures__nav { display: none; }
  }
  @media (max-width: 560px) {
    .tiles { grid-template-columns: 1fr; }
    .fieldnotes__grid { grid-template-columns: 1fr; }
  }
</style>
